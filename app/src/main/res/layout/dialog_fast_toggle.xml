<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="ContentDescription"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Material3.CardView.Outlined"
        android:backgroundTint="?attr/colorSurfaceContainerHighest"
        android:id="@+id/item_CardViewItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="15dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="15dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/item_cardView"
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_alignParentStart="true"
                android:layout_centerInParent="true"
                android:layout_marginStart="10dp"
                android:backgroundTint="@android:color/transparent"
                app:cardCornerRadius="3dp">

                <ImageView
                    android:id="@+id/menu_icon"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:scaleType="fitCenter"
                    tools:ignore="ContentDescription" />

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/textGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="5dp"
                android:layout_marginBottom="10dp"
                android:layout_toStartOf="@+id/buttonProfile"
                android:layout_toEndOf="@id/item_cardView"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textGroup_menuTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="2dp"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textGroup_menuURL"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOutline" />

            </LinearLayout>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/buttonProfile"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerInParent="true"
                android:layout_marginEnd="3dp"
                android:backgroundTint="?attr/colorSurfaceContainerHighest"
                app:backgroundTint="?attr/colorOutline"
                app:borderWidth="0.5dp"
                app:elevation="0dp"
                app:fabCustomSize="35dp"
                app:icon="@drawable/icon_profile_standard"
                app:maxImageSize="20dp" />

        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal">

        <Button
            android:id="@+id/ib_save"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            app:icon="@drawable/icon_menu_save" />

        <Button
            android:id="@+id/ib_delete"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:visibility="gone"
            app:icon="@drawable/icon_delete" />

        <Button
            android:id="@+id/ib_reload"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            app:icon="@drawable/icon_refresh" />

        <Button
            android:id="@+id/ib_settings"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            app:icon="@drawable/icon_settings"/>

        <Button
            android:id="@+id/button_help"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            app:icon="@drawable/icon_help"/>

    </LinearLayout>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <ScrollView android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:ignore="ContentDescription"
        android:paddingBottom="15dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="15dp"
                android:layout_marginStart="15dp"
                android:text="@string/setting_title_profiles_Security"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold"/>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_java"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_java"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />

                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_java"
                    android:layout_width="wrap_content"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_javascript"
                    android:layout_toEndOf="@+id/icon_java"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_javaPopUp"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_popup"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_javaPopUp"
                    android:layout_width="wrap_content"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_javascript_popUp"
                    android:layout_toEndOf="@+id/icon_javaPopUp"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_location"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_location"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_location"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_location"
                    android:layout_toEndOf="@+id/icon_location"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_camera"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_camera"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_camera"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_camera"
                    android:layout_toEndOf="@+id/icon_camera"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_mic"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_microphone"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_mic"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_microphone"
                    android:layout_toEndOf="@+id/icon_mic"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="15dp"
                android:layout_marginStart="15dp"
                android:text="@string/setting_title_profiles_privacy"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold"/>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_history"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_history"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_history"
                    android:layoutDirection="rtl"
                    android:text="@string/album_title_history"
                    android:layout_toEndOf="@+id/icon_history"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_cookies"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_cookie"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_cookies"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_cookie"
                    android:layout_toEndOf="@+id/icon_cookies"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_cookiesThirdParty"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_cookie"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_cookiesThirdParty"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_cookie_thirdParty"
                    android:layout_toEndOf="@+id/icon_cookiesThirdParty"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_cookiesBanner"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_cookie"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_cookiesBanner"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_deny_cookie_banners"
                    android:layout_toEndOf="@+id/icon_cookiesBanner"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_dom"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_dom"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_dom"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_dom"
                    android:layout_toEndOf="@+id/icon_dom"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_adBlock"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_adblock"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true"
                    tools:ignore="TooManyViews" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_adBlock"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_adblock"
                    android:layout_toEndOf="@+id/icon_adBlock"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_fingerPrint"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_fingerprint"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_fingerPrint"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_fingerPrint"
                    android:layout_toEndOf="@+id/icon_fingerPrint"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_trackingURL"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_tracking"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_trackingURL"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_trackingURL"
                    android:layout_toEndOf="@+id/icon_trackingURL"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="15dp"
                android:layout_marginStart="15dp"
                android:text="@string/setting_title_profiles_dataUsage"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold"/>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_image"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_image"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_image"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_images"
                    android:layout_toEndOf="@+id/icon_image"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_saveData"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_savedata"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_saveData"
                    android:layoutDirection="rtl"
                    android:text="@string/setting_title_save_data"
                    android:layout_toEndOf="@+id/icon_saveData"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="15dp"
                android:layout_marginStart="15dp"
                android:text="@string/setting_title_ui"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold"/>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_drm"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_movie"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_drm"
                    android:layoutDirection="rtl"
                    android:text="@string/hint_DRM_Media"
                    android:layout_toEndOf="@+id/icon_drm"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/layout_nightView"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_nightView"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_night"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_nightView"
                    android:layoutDirection="rtl"
                    android:text="@string/menu_nightView"
                    android:layout_toEndOf="@+id/icon_nightView"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_marginStart="15dp"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">
                <ImageView
                    android:id="@+id/icon_desktop"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_desktop"
                    android:layout_marginEnd="10dp"
                    android:layout_alignParentStart="true" />
                <CheckBox
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/checkbox_desktop"
                    android:layoutDirection="rtl"
                    android:text="@string/menu_desktopView"
                    android:layout_toEndOf="@+id/icon_desktop"
                    android:layout_width="wrap_content"
                    android:layout_height="?android:attr/listPreferredItemHeightSmall"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:id="@+id/titleViewSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="15dp"
                android:layout_marginStart="15dp"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold"/>

            <CheckBox
                android:ellipsize="end"
                android:maxLines="1"
                android:id="@+id/checkbox_screenOn"
                android:layoutDirection="rtl"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="15dp"
                android:text="@string/setting_title_screenOn"
                android:layout_width="match_parent"
                android:layout_height="?android:attr/listPreferredItemHeightSmall" />

            <CheckBox
                android:ellipsize="end"
                android:maxLines="1"
                android:id="@+id/checkbox_links"
                android:layoutDirection="rtl"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="15dp"
                android:text="@string/dialog_backGround"
                android:layout_width="match_parent"
                android:layout_height="?android:attr/listPreferredItemHeightSmall"
                tools:ignore="TooManyViews" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">

                <TextView
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:layout_marginEnd="5dp"
                    android:layoutDirection="rtl"
                    android:text="@string/privacy_redirect_use"
                    android:layout_toStartOf="@+id/item_checkBox"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>

                <Button
                    style="@style/Widget.Material3.Button.IconButton"
                    android:id="@+id/item_checkBox"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="2dp"
                    app:icon="@drawable/icon_redirect"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    tools:ignore="TooManyViews" />

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/checkbox_reset"
                android:layout_width="match_parent"
                android:layout_height="?android:attr/listPreferredItemHeightSmall">

                <TextView
                    android:ellipsize="end"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="15dp"
                    android:layout_marginEnd="5dp"
                    android:layoutDirection="rtl"
                    android:layout_centerVertical="true"
                    android:text="@string/setting_title_profiles_standard_always"
                    android:layout_toStartOf="@+id/icon_standard"
                    android:layout_alignParentStart="true" />

                <ImageView
                    android:id="@+id/icon_standard"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icon_popup"
                    android:layout_marginEnd="15dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>

            </RelativeLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>